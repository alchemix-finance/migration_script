# Alchemix V3 Migration Script — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# =============================================================================
# RPC Endpoints (required by Apeworx/Alchemy plugin)
# =============================================================================
# Used by `ape run` scripts and read_ids.py for on-chain queries.
# Get your API key at https://dashboard.alchemy.com/

ALCHEMY_API_KEY=your_alchemy_api_key_here

# Alternative: set explicit RPC URLs per chain (overrides Alchemy plugin)
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
# OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/your_key
# ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your_key

# =============================================================================
# Proposer Account (required for Safe transaction submission)
# =============================================================================
# The account that proposes transactions to the Gnosis Safe multisig.
# Must be a signer/owner on the migration multisig for each chain.
# This is a hex-encoded private key WITHOUT the 0x prefix.

PROPOSER_PRIVATE_KEY=abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890

# The Ethereum address of the proposer (derived from the private key above).
# Used to identify the Safe owner submitting the proposal.

PROPOSER_ADDRESS=0xYourProposerAddressHere

# =============================================================================
# Optional: Safe Transaction Service API overrides
# =============================================================================
# By default the scripts use the canonical Safe Transaction Service URLs:
#   mainnet:  https://safe-transaction-mainnet.safe.global
#   optimism: https://safe-transaction-optimism.safe.global
#   arbitrum: https://safe-transaction-arbitrum.safe.global
#
# Override only if using a custom Safe Transaction Service deployment.
# SAFE_API_URL_MAINNET=https://safe-transaction-mainnet.safe.global
# SAFE_API_URL_OPTIMISM=https://safe-transaction-optimism.safe.global
# SAFE_API_URL_ARBITRUM=https://safe-transaction-arbitrum.safe.global
